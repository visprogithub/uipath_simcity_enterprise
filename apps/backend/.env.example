# ─── UiPath Automation Cloud ─────────────────────────────────────────────────
# Required for real UiPath integration. Leave as-is for simulation-only mode.
UIPATH_CLOUD_URL=https://cloud.uipath.com
UIPATH_ORGANIZATION=your-org-name
UIPATH_TENANT=your-tenant-name

# External Application credentials (OAuth 2.0 client_credentials)
# Create at: Automation Cloud > Admin > External Applications > Add Application
# Required scopes: OR.Jobs OR.Folders OR.Robots OR.Actions OR.Execution
UIPATH_CLIENT_ID=your-client-id
UIPATH_CLIENT_SECRET=your-client-secret

# Orchestrator Folder ID (the MaestroCity folder)
# Find at: Orchestrator > Folders > your-folder > copy ID from URL
UIPATH_FOLDER_ID=your-folder-id

# Webhook secret for HMAC-SHA256 signature verification
# Set when creating the webhook in Orchestrator > Webhooks
UIPATH_WEBHOOK_SECRET=your-webhook-secret

# ─── Agent Builder: Orchestrator Process Names ───────────────────────────────
# Agent Builder agents are published as Orchestrator Processes and triggered via
# POST /odata/Jobs/UiPath.Server.Configuration.OData.StartJobs
# These names must match the Release names in your Orchestrator folder exactly.
UIPATH_ARIA_PROCESS_NAME=ARIA_Operations_Coordinator
UIPATH_SENTINEL_PROCESS_NAME=SENTINEL_Incident_Response
UIPATH_VERITAS_PROCESS_NAME=VERITAS_Compliance
UIPATH_ECHO_PROCESS_NAME=ECHO_Communications
UIPATH_APEX_PROCESS_NAME=APEX_Executive_Strategy

# ─── Integration Service API Trigger Slugs ───────────────────────────────────
# API Triggers are created in Orchestrator > Triggers > API Triggers.
# Slug is the unique path assigned when creating the trigger.
# Docs: https://docs.uipath.com/orchestrator/latest/user-guide/managing-api-triggers
UIPATH_TRIGGER_EHR_SLUG=ehr-availability-check
UIPATH_TRIGGER_PHARMACY_SLUG=pharmacy-inventory-sync
UIPATH_TRIGGER_STAFFING_SLUG=staffing-status-update
UIPATH_TRIGGER_OUTAGE_SLUG=outage-notification
UIPATH_TRIGGER_ESCALATION_SLUG=escalation-notify

# ─── Coding Agent (Claude AI) ────────────────────────────────────────────────
# Required for the Coding Agent bonus feature (AI-generated XAML workflows).
# Without this key the feature runs in demo mode with realistic mock responses.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Simulation Settings ─────────────────────────────────────────────────────
SIMULATION_TICK_INTERVAL=1.0
