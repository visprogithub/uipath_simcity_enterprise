# Backend URL — set this to your deployed backend when running the frontend on Vercel.
# The WebSocket URL is derived automatically (http→ws, https→wss) unless you override it.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Override the WebSocket URL explicitly if needed (e.g. wss:// behind a reverse proxy).
# NEXT_PUBLIC_WS_URL=wss://your-backend.railway.app/ws
